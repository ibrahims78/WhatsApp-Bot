FROM node:20-bullseye-slim

# Install Chromium + all required system dependencies for WPPConnect/Puppeteer
RUN apt-get update && apt-get install -y --no-install-recommends \
    chromium \
    ca-certificates \
    fonts-liberation \
    fonts-noto-color-emoji \
    libasound2 \
    libatk-bridge2.0-0 \
    libatk1.0-0 \
    libcairo2 \
    libcups2 \
    libdbus-1-3 \
    libexpat1 \
    libfontconfig1 \
    libgbm1 \
    libglib2.0-0 \
    libgtk-3-0 \
    libnspr4 \
    libnss3 \
    libpango-1.0-0 \
    libpangocairo-1.0-0 \
    libstdc++6 \
    libx11-6 \
    libx11-xcb1 \
    libxcb1 \
    libxcomposite1 \
    libxcursor1 \
    libxdamage1 \
    libxext6 \
    libxfixes3 \
    libxi6 \
    libxrandr2 \
    libxrender1 \
    libxss1 \
    libxtst6 \
    wget \
    xdg-utils \
    && rm -rf /var/lib/apt/lists/*

ENV CHROME_PATH=/usr/bin/chromium
ENV PUPPETEER_SKIP_DOWNLOAD=true
ENV NODE_ENV=development

RUN npm install -g pnpm@10

WORKDIR /app

COPY pnpm-workspace.yaml package.json pnpm-lock.yaml tsconfig.base.json tsconfig.json ./
COPY lib/ ./lib/
COPY artifacts/api-server/ ./artifacts/api-server/
COPY doc/ ./doc/

# Copy package.json stubs for other workspace packages so pnpm resolves the
# full workspace graph and properly installs all binaries (e.g. drizzle-kit)
COPY artifacts/whatsapp-dashboard/package.json ./artifacts/whatsapp-dashboard/

# Install all dependencies including devDependencies
RUN pnpm install --frozen-lockfile

RUN mkdir -p /app/artifacts/api-server/tokens /app/artifacts/api-server/public

COPY entrypoint.dev.sh /entrypoint.dev.sh
RUN sed -i 's/\r$//' /entrypoint.dev.sh && chmod +x /entrypoint.dev.sh

EXPOSE 8080

CMD ["/entrypoint.dev.sh"]
