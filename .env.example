# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=wauser
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=whatsapp_manager_db

# ─── API Security ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 48
JWT_SECRET=your_jwt_secret_here

# ─── App Port ─────────────────────────────────────────────────────────────────
APP_PORT=5005

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed external origins (your public domain(s))
# Required when accessing the app through a reverse proxy or custom domain
# Example: ALLOWED_ORIGINS=https://wa.yourdomain.com
# Example (multiple): ALLOWED_ORIGINS=https://wa.yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS=https://wa.yourdomain.com
